# Supabase — get from https://supabase.com/dashboard/project/YOUR_PROJECT/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Better Auth — generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=your_32_char_secret_here
BETTER_AUTH_URL=http://localhost:3000

# ── Build / CI ───────────────────────────────────────────────────────────
# Set to '1' in CI/preview builds to skip Zod env validation at startup.
# Required when env vars are not available during the Next.js build step.
# Never set this in production.
# SKIP_ENV_VALIDATION=1
